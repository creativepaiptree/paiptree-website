<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.paiptree.cctvup-check</string>

  <key>WorkingDirectory</key>
  <string>/Users/zoro/company/paiptree-website</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/zoro/company/paiptree-website/scripts/cctvup-check-local.mjs</string>
  </array>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/paiptree-cctvup-check.out.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/paiptree-cctvup-check.err.log</string>
</dict>
</plist>
